{
	"compatibility_date": "2025-10-08",
	"main": "src/index.ts",
	"name": "news-summarizer",
	"upload_source_maps": true,
	"triggers": {
		"crons": [
			"*/10 * * * *"
		]
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "newsdb",
			"database_id": "c119f765-e583-4392-a24c-da7c3cefeecd",
			"remote": true
		}
	],
	"ai": {
		"binding": "AI"
	},
	"vars": {
		"FACEBOOK_TOKEN": ""
	}
}